<!DOCTYPE html>
<!-- Derniere modification: 2026-07-13 20:30:00 - Suppression doublon titre generateModuleConfigForm, correction /\> dans generateFieldHtml (hint deplacé après balise) -->
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="HA WS/MQTT Application - Configuration Interface">
  <title>HA WS/MQTT</title>
  
  <!-- ====================================================================== -->
  <!-- CONFIGURATION ALPINE JS -->
  <!-- ====================================================================== -->
  
  <!-- Defer Alpine start to prevent race conditions -->
  <script>window.deferAlpineStart = true;</script>
  
  <!-- Socket.io client via CDN -->
  <script src="https://cdn.socket.io/4.5.4/socket.io.min.js" defer></script>
  
  <!-- Alpine.js via CDN -->
  <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
  
  <!-- Charger les composants RFXCOM AVANT Alpine ne parse le DOM -->
  <script src="/applications/rfxcom/presentation/components/rfxcom-components.js" defer></script>
  
  <!-- Définir les stores AVANT qu'Alpine ne parse le DOM -->
  <script defer>
    // === TRACES TOUS LES ÉVÉNEMENTS ALPINE ===
    const alpineEvents = ['init', 'initializing', 'initialized', 'initing', 'start', 'started', 'ready', 'morph', 'updated'];
    alpineEvents.forEach(eventName => {
      document.addEventListener(`alpine:${eventName}`, () => {
        console.log(`[TRACE ALPINE] Événement: alpine:${eventName} - ${new Date().toISOString()}`);
      });
    });
    
    document.addEventListener('alpine:init', () => {
      console.log('[ALPINE STORE] alpine:init - Début définition des stores (AVANT scan DOM)');
      // Store principal de l'application
      Alpine.store('appStore', {
        socket: null,
        technicalConfig: {
          ha: {
            ws_enable: false,
            mqtt_enable: false,
            ws: { host: '', port: 8123, token: '', reconnect_delay: 5 },
            mqtt: { host: '', port: 1883, client_id: 'ha-app-unique-id', username: '', password: '', keepalive: 60, reconnect_delay: 5 },
            structure: { include_unassigned: false, unassigned_label: 'Non assigné' }
          },
          web: { port: 8080, host: '0.0.0.0' },
          logging: { level: 'info', rotate: { max_size_mb: 10, max_files: 5 } }
        },
        validationResult: { valid: false, errors: [], warnings: [], requiredMissing: [] },
        saveInProgress: false,
        isLoading: true,
        isHaConnected: null,
        uptime: 0,
        modules: [],
        moduleContents: {},
        moduleUiMetadata: {},
        moduleConfigs: {},
        init() {
          console.log('[TRACE SOCKET] Début déclaration des écouteurs Socket.io');
          this.socket = io();
          this.socket.emit('config:get');
          console.log('[TRACE SOCKET] Événement: config:get émis');
          this.socket.on('connect', () => { 
            console.log('[TRACE SOCKET] Écouteur: connect'); 
            this.isLoading = false; 
          });
          this.socket.on('config:current', (c) => {
            console.log('[TRACE SOCKET] Écouteur: config:current - données reçues');
            const mergeDeep = (target, source) => {
              // Create a copy of target
              const result = {...target};
              for (const key in source) {
                if (source[key] && typeof source[key] === 'object' && !Array.isArray(source[key])) {
                  if (!result[key]) result[key] = {};
                  result[key] = mergeDeep(result[key], source[key]);
                } else {
                  result[key] = source[key];
                }
              }
              return result;
            };
            this.technicalConfig = mergeDeep({...this.technicalConfig}, c);
            this.isLoading = false;
          });
          this.socket.on('config:validation:result', (r) => { 
            console.log('[TRACE SOCKET] Écouteur: config:validation:result'); 
            this.validationResult = r; 
          });
          this.socket.on('app:modules:list', (d) => { 
            console.log('[TRACE SOCKET] Écouteur: app:modules:list - modules:', d.modules.map(m => m.id));
            this.modules = d.modules; 
            window.dispatchEvent(new CustomEvent('app-modules-loaded', { detail: { modules: d.modules } })); 
          });
          this.socket.on('ha:connected', () => { 
            console.log('[TRACE SOCKET] Écouteur: ha:connected'); 
            this.isHaConnected = true; 
          });
          this.socket.on('ha:disconnected', () => { 
            console.log('[TRACE SOCKET] Écouteur: ha:disconnected'); 
            this.isHaConnected = false; 
          });
          this.socket.on('app:started', () => { 
            console.log('[TRACE SOCKET] Écouteur: app:started'); 
            this.uptime = Date.now(); 
          });
          this.socket.on('app:module:ui:register', (data) => {
            console.log('[TRACE SOCKET] Écouteur: app:module:ui:register - module:', data.moduleId);
            this.moduleUiMetadata[data.moduleId] = data.metadata;
            console.log('[TRACE SOCKET] Métadonnées UI stockées pour module:', data.moduleId, 'metadata:', data.metadata);
            console.log('[TRACE METADATA] moduleUiMetadata APRES stockage:', Object.keys(this.moduleUiMetadata));
          });
          console.log('[TRACE SOCKET] Fin déclaration des écouteurs Socket.io');
        },
        saveConfig() { 
          this.saveInProgress = true; 
          this.socket.emit('config:save:requested', this.technicalConfig); 
        },
        validateField(fieldPath) {
          const errors = this.validationResult.errors || [];
          const error = errors.find(e => e.path === fieldPath);
          return { isValid: !error, errorMessage: error ? error.message : '' };
        },
        getFieldStatusClass(fieldPath) { 
          return this.validateField(fieldPath).isValid ? '' : 'field-invalid'; 
        },
        formatUptime(ts) {
          if (!ts) return '0s';
          const sec = Math.floor((Date.now() - ts) / 1000);
          if (sec < 60) return sec + 's';
          const min = Math.floor(sec / 60);
          if (min < 60) return min + 'm ' + sec % 60 + 's';
          const h = Math.floor(min / 60);
          return h + 'h ' + min % 60 + 'm';
        },
        scrollToSection(sectionId) {
          const el = document.getElementById(sectionId);
          if (el) el.scrollIntoView({ behavior: 'smooth' });
        },
        scrollToField(fieldPath) {
          const field = document.querySelector(`[x-model*="${fieldPath}"]`);
          if (field) field.scrollIntoView({ behavior: 'smooth', block: 'center' });
        },
        getSectionLabel(section) {
          const labels = { global: 'Global', ha: 'Web-Services', mqtt: 'MQTT', web: 'Web', logging: 'Logging', rfxcom: 'RFXCOM' };
          return labels[section] || section;
        },
        generateModuleConfigForm(moduleId) {
          const metadata = this.moduleUiMetadata[moduleId];
          console.log('[TRACE FORM] generateModuleConfigForm appelé pour:', moduleId, 'metadata existe:', !!metadata);
          if (!metadata) {
            return `<div class="error-hint">Métadonnées UI non disponibles pour ${moduleId}</div>`;
          }
          if (!this.moduleConfigs[moduleId]) {
            this.moduleConfigs[moduleId] = {};
          }
          const config = this.moduleConfigs[moduleId];
          const fields = metadata.fields || [];
          let html = '';
          html += '<form onsubmit="return false" class="config-grid module-config-form">';
          for (const field of fields) {
            html += this.generateFieldHtml(field, config, moduleId);
          }
          html += '</form>';
          return html;
        },
        generateFieldHtml(field, config, moduleId) {
          const fieldName = field.name;
          const value = config[fieldName] !== undefined ? config[fieldName] : field.default || '';
          const id = `field-${moduleId}-${fieldName}`;
          let html = `
            <div class="form-group" id="${id}">
              <label for="${id}">
                ${field.label}
                ${field.required ? '<span class="required-badge">Requis</span>' : ''}
              </label>
          `;
          switch (field.type) {
            case 'text':
              html += `
                <input 
                  type="text" 
                  id="${id}"
                  :value="$store.appStore.getModuleField('${moduleId}', '${fieldName}')"
                  @input="$store.appStore.setModuleField($event, '${moduleId}', '${fieldName}')"
                  @change.debounce.500ms="$store.appStore.saveModuleConfig('${moduleId}')"
                  ${field.placeholder ? `placeholder="${field.placeholder}"` : ''}
                >
              `;
              if (field.hint) {
                html += `<div class="field-hint">${field.hint}</div>`;
              }
              break;
            case 'number':
              html += `
                <input 
                  type="number" 
                  id="${id}"
                  :value="$store.appStore.getModuleField('${moduleId}', '${fieldName}')"
                  @input="$store.appStore.setModuleField($event, '${moduleId}', '${fieldName}')"
                  @change.debounce.500ms="$store.appStore.saveModuleConfig('${moduleId}')"
                  ${field.min !== undefined ? `min="${field.min}"` : ''}
                  ${field.max !== undefined ? `max="${field.max}"` : ''}
                  ${field.step !== undefined ? `step="${field.step}"` : ''}
                  ${field.placeholder ? `placeholder="${field.placeholder}"` : ''}
                >
              `;
              if (field.hint) {
                html += `<div class="field-hint">${field.hint}</div>`;
              }
              break;
            case 'boolean':
              html += `
                <input 
                  type="checkbox" 
                  id="${id}"
                  :checked="$store.appStore.getModuleField('${moduleId}', '${fieldName}')"
                  @change="$store.appStore.toggleModuleField('${moduleId}', '${fieldName}'); $store.appStore.saveModuleConfig('${moduleId}')"
                >
              `;
              if (field.hint) {
                html += `<div class="field-hint">${field.hint}</div>`;
              }
              break;
            case 'select':
              html += `
                <select 
                  id="${id}"
                  :value="$store.appStore.getModuleField('${moduleId}', '${fieldName}')"
                  @change="$store.appStore.setSelectField($event, '${moduleId}', '${fieldName}'); $store.appStore.saveModuleConfig('${moduleId}')"
                >
                  ${field.options ? field.options.map(opt => 
                    `<option value="${opt.value}">${opt.label}</option>`
                  ).join('') : ''}
                </select>
              `;
              if (field.hint) {
                html += `<div class="field-hint">${field.hint}</div>`;
              }
              break;
            case 'password':
              html += `
                <input 
                  type="password" 
                  id="${id}"
                  :value="$store.appStore.getModuleField('${moduleId}', '${fieldName}')"
                  @input="$store.appStore.setModuleField($event, '${moduleId}', '${fieldName}')"
                  @change.debounce.500ms="$store.appStore.saveModuleConfig('${moduleId}')"
                  autocomplete="off"
                  ${field.placeholder ? `placeholder="${field.placeholder}"` : ''}
                >
              `;
              if (field.hint) {
                html += `<div class="field-hint">${field.hint}</div>`;
              }
              break;
          }
          html += '</div>';
          return html;
        },
        getModuleField(moduleId, fieldName) {
          const moduleConfig = this.moduleConfigs[moduleId] || {};
          return moduleConfig[fieldName] !== undefined ? moduleConfig[fieldName] : '';
        },
        setModuleField(event, moduleId, fieldName) {
          if (!this.moduleConfigs[moduleId]) {
            this.moduleConfigs[moduleId] = {};
          }
          this.moduleConfigs[moduleId][fieldName] = event.target.type === 'number' 
            ? parseFloat(event.target.value) || 0 
            : event.target.value;
        },
        toggleModuleField(moduleId, fieldName) {
          if (!this.moduleConfigs[moduleId]) {
            this.moduleConfigs[moduleId] = {};
          }
          this.moduleConfigs[moduleId][fieldName] = !this.moduleConfigs[moduleId][fieldName];
        },
        setSelectField(event, moduleId, fieldName) {
          if (!this.moduleConfigs[moduleId]) {
            this.moduleConfigs[moduleId] = {};
          }
          this.moduleConfigs[moduleId][fieldName] = event.target.value;
        },
        saveModuleConfig(moduleId) {
          this.saveInProgress = true;
          const config = this.moduleConfigs[moduleId] || {};
          this.socket.emit('app:modules:config:save', { moduleId, config });
          setTimeout(() => { this.saveInProgress = false; }, 1000);
        }
      });
      
      // Store de la barre latérale
      Alpine.store('sidebarStore', {
        modules: [],
        activeModule: null,
        loadModules(m) { 
          const modules = m.detail?.modules || m;
          console.log('[TRACE MODULE] Début chargement modules:', modules.map(module => module.id));
          this.modules = modules; 
          
          // Ajouter RFXCOM manuellement s'il n'est pas déjà présent
          const hasRfxcom = this.modules.some(module => module.id === 'rfxcom');
          if (!hasRfxcom) {
            console.log('[TRACE MODULE] Ajout manuel de RFXCOM aux modules');
            this.modules.push({
              id: 'rfxcom',
              name: 'RFXCOM',
              icon: '📡',
              status: 'configured',
              configUi: {
                title: 'RFXCOM',
                description: 'Configuration technique du module RFXCOM',
                fields: []
              }
            });
          } else {
            console.log('[TRACE MODULE] RFXCOM déjà présent dans les modules');
          }
          
          if (m.length > 0) this.activeModule = m[0].id; 
          console.log('[TRACE MODULE] Modules chargés:', this.modules.map(module => module.id));
        },
        setActiveModule(id) { 
          console.log('[TRACE MODULE] Module actif défini:', id);
          this.activeModule = id; 
        },
        getModule(id) { 
          console.log('[TRACE MODULE] Recherche module:', id);
          return this.modules.find(x => x.id === id); 
        },
        getModuleStatusClass(id) {
          const m = this.getModule(id);
          if (!m) return '';
          return { configured: 'status-configured', partial: 'status-partial', missing: 'status-missing', error: 'status-error' }[m.status] || '';
        },
        getModuleStatusIcon(id) {
          const m = this.getModule(id);
          if (!m) return '';
          return { configured: '\u2713', partial: '\u26A0', missing: '\u2717', error: '\u2718' }[m.status] || '';
        }
      });
      
      // Store du contenu principal
      Alpine.store('mainContentStore', {
        activeModule: 'core',
        modules: [],
        moduleContents: {},
        moduleInited: {},
        get technicalConfig() { return Alpine.store('appStore').technicalConfig; },
        async loadModuleContent(moduleId, element) {
          if (this.moduleContents[moduleId] && this.moduleInited[moduleId]) return;
          try {
            const response = await fetch(`/applications/${moduleId}/presentation/index.html`);
            if (response.ok) {
              const html = await response.text();
              this.moduleContents[moduleId] = html;
              if (element) {
                element.innerHTML = html;
                if (typeof Alpine !== 'undefined') {
                  Alpine.initTree(element);
                  this.moduleInited[moduleId] = true;
                }
              }
            } else {
              this.moduleContents[moduleId] = `<div class=\"error-hint\">Impossible de charger le module ${moduleId}</div>`;
            }
          } catch (error) {
            this.moduleContents[moduleId] = `<div class=\"error-hint\">Erreur de chargement: ${error.message}</div>`;
          }
        }
      });
      
      // Store de la modale des logs
      Alpine.store('logsModalStore', {
        show: false,
        logs: [],
        open() { this.show = true; },
        close() { this.show = false; }
      });
      
      // Store pour RFXCOM
      Alpine.store('rfxcomStore', function() {
        return {
          activeTab: 'devices',
          componentsLoaded: {
            devices: false,
            receivers: false,
            scenes: false,
          },
          components: {
            devices: '',
            receivers: '',
          },
          stats: {
            devicesCount: 0,
            receiversCount: 0,
            scenesCount: 0,
          },
          isSyncing: false,
          rfxcomConnected: true,
          initialized: false,
          
          get socket() {
            return Alpine.store('appStore')?.socket || window.socket || (typeof io !== 'undefined' ? io() : null);
          },
          
          init() {
            if (this.initialized) return;
            this.initialized = true;
            const sock = this.socket;
            if (sock) {
              sock.on('rfxcom:status', (status) => {
                this.stats.devicesCount = status.devicesCount || 0;
                this.stats.receiversCount = status.receiversCount || 0;
                this.stats.scenesCount = status.scenesCount || 0;
                this.rfxcomConnected = status.connected || false;
              });
              
              sock.emit('rfxcom:status');
              this.loadComponents();
            }
          },
          
          loadComponents() {
            this.loadComponent('devices');
            this.loadComponent('receivers');
          },
          
          loadComponent(name) {
            fetch(`/applications/rfxcom/presentation/components/${name}.html`)
              .then(response => {
                if (!response.ok) throw new Error('Component not found');
                return response.text();
              })
              .then(html => {
                this.components[name] = html;
                this.componentsLoaded[name] = true;
              })
              .catch(error => {
                console.error(`Erreur de chargement du composant ${name}:`, error);
                this.components[name] = `<div class=\"error-placeholder\">Erreur de chargement du composant ${name}</div>`;
                this.componentsLoaded[name] = true;
              });
          },
          
          getComponent(name) {
            return this.components[name];
          },
          
          setActiveTab(tab) {
            this.activeTab = tab;
          },
          
          syncWithHa() {
            const sock = this.socket;
            if (sock) {
              this.isSyncing = true;
              sock.emit('rfxcom:ha:sync');
              setTimeout(() => { this.isSyncing = false; }, 3000);
            }
          },
          
          reconnectRfxcom() {
            const sock = this.socket;
            if (sock) sock.emit('rfxcom:reconnect');
          },
        };
      });
    });
    
    // Start Alpine after all stores are defined
    // Vérifier qu'Alpine est chargé avant de démarrer
    let alpineStarted = false;
    function startAlpineSafely() {
      if (alpineStarted) {
        console.log('[ALPINE] Déjà démarré, ignore appel supplémentaire');
        return;
      }
      if (typeof Alpine !== 'undefined') {
        console.log('[ALPINE] Premier démarrage de Alpine mis en commentaire');
       // Alpine.start();
        alpineStarted = true;
      } else {
        // Alpine n'est pas encore chargé, essayer plus tard
        console.log('[ALPINE] Alpine non chargé, réessaye dans 100ms...');
        setTimeout(startAlpineSafely, 100);
      }
    }
    
    // Démarrer Alpine dès qu'il est disponible
    if (typeof Alpine === 'undefined') {
      // Alpine pas encore chargé, attendre
      console.log('[ALPINE] Alpine non disponible au chargement du script, attend DOMContentLoaded');
      document.addEventListener('DOMContentLoaded', startAlpineSafely);
    } else {
      console.log('[ALPINE] Alpine disponible, démarrage...');
      startAlpineSafely();
    }
  </script>
  
  <!-- Styles communs -->
  <link rel="stylesheet" href="/styles/general.css">
  <link rel="stylesheet" href="/styles/alert-banner.css">
  <link rel="stylesheet" href="/styles/config-form.css">
  
  <!-- Styles spécifiques applications -->
  <link rel="stylesheet" href="/applications/rfxcom/styles/rfxcom.css">
</head>
<body @alpine-init.window="$store.appStore.init()">

  <!-- ====================================================================== -->
  <!-- MAIN CONTAINER -->
  <!-- ====================================================================== -->
  <div class="app-container">
    <!-- ====================================================================== -->
    <!-- SIDEBAR - Menu des applications -->
    <!-- ====================================================================== -->
    <aside class="sidebar" x-data="$store.sidebarStore" @app-modules-loaded.window="$store.sidebarStore.loadModules($event)">
      <div class="sidebar-header">
        <h1 class="app-title">
          <span>HA/MQTT</span>
        </h1>
        <p class="app-subtitle">Configuration Interface</p>
      </div>
      
      <nav class="sidebar-nav">
        <h2 class="nav-title">Applications</h2>
        <ul class="nav-list">
          <!-- Module Core (Paramètres Techniques) -->
          <li class="nav-item" :class="{ 'nav-item-active': $store.mainContentStore.activeModule === 'core' }">
            <a href="#core" @click.prevent="$store.sidebarStore.setActiveModule('core')" class="nav-link">
              <span class="nav-icon">⚙️</span>
              <span class="nav-label">Paramètres Techniques</span>
              <span class="nav-status" :class="$store.sidebarStore.getModuleStatusClass('core')">
                <template x-if="$store.sidebarStore.getModule('core')">
                  <span x-text="$store.sidebarStore.getModuleStatusIcon('core')"></span>
                </template>
              </span>
            </a>
          </li>
          
          <!-- Module RFXCOM (statique) -->
          <li class="nav-item" :class="{ 'nav-item-active': $store.mainContentStore.activeModule === 'rfxcom' }">
            <a href="#rfxcom" @click.prevent="$store.sidebarStore.setActiveModule('rfxcom')" class="nav-link">
              <span class="nav-icon">📡</span>
              <span class="nav-label">RFXCOM</span>
              <span class="nav-status" :class="$store.sidebarStore.getModuleStatusClass('rfxcom')">
                <template x-if="$store.sidebarStore.getModule('rfxcom')">
                  <span x-text="$store.sidebarStore.getModuleStatusIcon('rfxcom')"></span>
                </template>
              </span>
            </a>
          </li>
          
          <!-- Modules dynamiques -->
          <template x-for="module in $store.sidebarStore.modules" :key="module.id">
            <li 
              class="nav-item" 
              :class="{ 'nav-item-active': $store.mainContentStore.activeModule === module.id }"
              x-show="module.id !== 'core' && module.id !== 'rfxcom'">
              <a :href="`'#' + module.id`" @click.prevent="$store.sidebarStore.setActiveModule(module.id)" class="nav-link">
                <span class="nav-icon" x-text="module.icon"></span>
                <span class="nav-label" x-text="module.name"></span>
                <span class="nav-status" :class="$store.sidebarStore.getModuleStatusClass(module.id)">
                  <span x-text="$store.sidebarStore.getModuleStatusIcon(module.id)"></span>
                </span>
              </a>
            </li>
          </template>
        </ul>
      </nav>
      
      <div class="sidebar-footer">
        <div class="status-indicator" :class="{ 'status-connected': $store.appStore.isHaConnected }" x-show="$store.appStore.isHaConnected !== null">
          <span class="status-dot"></span>
          <span>Web-Services</span>
        </div>
        <div class="uptime">
          Uptime: <span x-text="$store.appStore.formatUptime($store.appStore.uptime)"></span>
        </div>
      </div>
    </aside>

    <!-- ====================================================================== -->
    <!-- MAIN CONTENT -->
    <!-- ====================================================================== -->
    <main class="main-content" x-data="$store.mainContentStore">
      <!-- Section Core - Paramètres Techniques -->
      <section id="core" class="content-section" x-show="$store.mainContentStore.activeModule === 'core'" x-transition>
        <h2>⚙️ Paramètres Techniques</h2>
        <p class="section-description">
          Configuration globale de l'application (HA, MQTT, Web, Logging)
        </p>
        
        <!-- Formulaire HA WebSocket -->
        <div id="config-section-ha" class="config-section">
          <h3>Web-Services</h3>
          
          <form onsubmit="return false" class="config-grid">
            <!-- Activation Web-Services -->
            <div class="form-group" id="field-ha-ws-enable">
              <label for="ha-ws-enable">
                Activer Web-Services
              </label>
              <input 
                type="checkbox" 
                id="ha-ws-enable"
                x-model="$store.appStore.technicalConfig.ha.ws_enable"
                @change.debounce.500ms="$store.appStore.saveConfig()"
              />
            </div>
            <div class="form-group" id="field-ha-ws-host">
              <label for="ha-ws-host">
                Hôte *
                <span class="required-badge">Requis</span>
              </label>
              <input 
                type="text" 
                id="ha-ws-host"
                x-model="$store.appStore.technicalConfig.ha.ws.host"
                @change.debounce.500ms="$store.appStore.saveConfig()"
                :class="$store.appStore.getFieldStatusClass('ha.ws.host')"
                placeholder="192.168.1.x"
              />
              <div class="field-feedback" 
                   x-show="!$store.appStore.validateField('ha.ws.host').isValid"
                   x-text="$store.appStore.validateField('ha.ws.host').errorMessage">
              </div>
            </div>
            
            <div class="form-group" id="field-ha-ws-port">
              <label for="ha-ws-port">Port</label>
              <input 
                type="number" 
                id="ha-ws-port"
                x-model.number="$store.appStore.technicalConfig.ha.ws.port"
                @change.debounce.500ms="$store.appStore.saveConfig()"
                min="1"
                max="65535"
              />
              <div class="field-hint">Port par défaut : 8123</div>
            </div>
            
            <div class="form-group" id="field-ha-ws-token">
              <label for="ha-ws-token">
                Long-Lived Access Token *
                <span class="required-badge">Requis</span>
              </label>
              <input 
                type="password" 
                id="ha-ws-token"
                x-model="$store.appStore.technicalConfig.ha.ws.token"
                @change.debounce.500ms="$store.appStore.saveConfig()"
                :class="$store.appStore.getFieldStatusClass('ha.ws.token')"
                autocomplete="off"
              />
              <div class="field-feedback" 
                   x-show="!$store.appStore.validateField('ha.ws.token').isValid"
                   x-text="$store.appStore.validateField('ha.ws.token').errorMessage">
              </div>
            </div>
            
            <div class="form-group" id="field-ha-ws-reconnect_delay">
              <label for="ha-ws-reconnect_delay">Délai de reconnexion (secondes)</label>
              <input 
                type="number" 
                id="ha-ws-reconnect_delay"
                x-model.number="$store.appStore.technicalConfig.ha.ws.reconnect_delay"
                @change.debounce.500ms="$store.appStore.saveConfig()"
                min="0"
                max="60"
              />
              <div class="field-hint">Backoff exponentiel, plafond à 60s</div>
            </div>
          </form>
        </div>

        <!-- Section MQTT (conditionnelle) -->
        <div id="config-section-mqtt" 
             class="config-section" 
             x-show="$store.appStore.technicalConfig.ha.mqtt !== undefined"
             x-transition>
          
          <h3>📡 MQTT (Broker Externe)</h3>
          <p class="section-hint">
            Configurer uniquement si cette application est de type "intégration"
          </p>
          
          <form onsubmit="return false" class="config-grid">
            <!-- Activation MQTT -->
            <div class="form-group" id="field-mqtt-enable">
              <label for="mqtt-enable">
                Activer MQTT
              </label>
              <input 
                type="checkbox" 
                id="mqtt-enable"
                x-model="$store.appStore.technicalConfig.ha.mqtt_enable"
                @change.debounce.500ms="$store.appStore.saveConfig()"
              />
            </div>
            <div class="form-group" id="field-mqtt-host">
              <label for="mqtt-host">
                Hôte *
                <span class="required-badge">Requis</span>
              </label>
              <input 
                type="text" 
                id="mqtt-host"
                x-model="$store.appStore.technicalConfig.ha.mqtt.host"
                @change.debounce.500ms="$store.appStore.saveConfig()"
                :class="$store.appStore.getFieldStatusClass('ha.mqtt.host')"
                placeholder="192.168.1.x"
              />
              <div class="field-feedback" 
                   x-show="!$store.appStore.validateField('ha.mqtt.host').isValid"
                   x-text="$store.appStore.validateField('ha.mqtt.host').errorMessage">
              </div>
            </div>
            
            <div class="form-group" id="field-mqtt-port">
              <label for="mqtt-port">Port</label>
              <input 
                type="number" 
                id="mqtt-port"
                x-model.number="$store.appStore.technicalConfig.ha.mqtt.port"
                @change.debounce.500ms="$store.appStore.saveConfig()"
                min="1"
                max="65535"
                placeholder="1883"
              />
            </div>
            
            <div class="form-group" id="field-mqtt-client_id">
              <label for="mqtt-client_id">
                Client ID *
                <span class="required-badge">Requis</span>
              </label>
              <input 
                type="text" 
                id="mqtt-client_id"
                x-model="$store.appStore.technicalConfig.ha.mqtt.client_id"
                @change.debounce.500ms="$store.appStore.saveConfig()"
                :class="$store.appStore.getFieldStatusClass('ha.mqtt.client_id')"
                placeholder="ha-app-unique-id"
              />
              <div class="field-hint">Doit être unique par application</div>
              <div class="field-feedback" 
                   x-show="!$store.appStore.validateField('ha.mqtt.client_id').isValid"
                   x-text="$store.appStore.validateField('ha.mqtt.client_id').errorMessage">
              </div>
            </div>
            
            <div class="form-group" id="field-mqtt-username">
              <label for="mqtt-username">Identifiant (optionnel)</label>
              <input 
                type="text" 
                id="mqtt-username"
                x-model="$store.appStore.technicalConfig.ha.mqtt.username"
                @change.debounce.500ms="$store.appStore.saveConfig()"
                autocomplete="off"
              />
            </div>
            
            <div class="form-group" id="field-mqtt-password">
              <label for="mqtt-password">Mot de passe (optionnel)</label>
              <input 
                type="password" 
                id="mqtt-password"
                x-model="$store.appStore.technicalConfig.ha.mqtt.password"
                @change.debounce.500ms="$store.appStore.saveConfig()"
                autocomplete="off"
              />
            </div>
            
            <div class="form-group" id="field-mqtt-keepalive">
              <label for="mqtt-keepalive">Keepalive (secondes)</label>
              <input 
                type="number" 
                id="mqtt-keepalive"
                x-model.number="$store.appStore.technicalConfig.ha.mqtt.keepalive"
                @change.debounce.500ms="$store.appStore.saveConfig()"
                min="0"
                placeholder="60"
              />
            </div>
            
            <div class="form-group" id="field-mqtt-reconnect_delay">
              <label for="mqtt-reconnect_delay">Délai de reconnexion (secondes)</label>
              <input 
                type="number" 
                id="mqtt-reconnect_delay"
                x-model.number="$store.appStore.technicalConfig.ha.mqtt.reconnect_delay"
                @change.debounce.500ms="$store.appStore.saveConfig()"
                min="0"
                max="60"
              />
            </div>
          </form>
        </div>

        <!-- Section Web -->
        <div id="config-section-web" class="config-section">
          <h3>🌐 Serveur Web</h3>
          
          <div class="config-grid">
            <div class="form-group" id="field-web-port">
              <label for="web-port">Port</label>
              <input 
                type="number" 
                id="web-port"
                x-model.number="$store.appStore.technicalConfig.web.port"
                @change.debounce.500ms="$store.appStore.saveConfig()"
                min="1"
                max="65535"
                placeholder="8080"
              />
            </div>
            
            <div class="form-group" id="field-web-host">
              <label for="web-host">Hôte</label>
              <input 
                type="text" 
                id="web-host"
                x-model="$store.appStore.technicalConfig.web.host"
                @change.debounce.500ms="$store.appStore.saveConfig()"
                placeholder="0.0.0.0"
              />
            </div>
          </div>
        </div>

        <!-- Section Logging -->
        <div id="config-section-logging" class="config-section">
          <h3>📝 Journalisation</h3>
          
          <div class="config-grid">
            <div class="form-group" id="field-logging-level">
              <label for="logging-level">Niveau de log</label>
              <select 
                id="logging-level"
                x-model="$store.appStore.technicalConfig.logging.level"
                @change.debounce.500ms="$store.appStore.saveConfig()"
              >
                <option value="debug">Debug</option>
                <option value="info">Info</option>
                <option value="warn">Warning</option>
                <option value="error">Error</option>
              </select>
            </div>
            
            <div class="form-group" id="field-logging-max_size_mb">
              <label for="logging-max_size_mb">Taille max par fichier (Mo)</label>
              <input 
                type="number" 
                id="logging-max_size_mb"
                x-model.number="$store.appStore.technicalConfig.logging.rotate.max_size_mb"
                @change.debounce.500ms="$store.appStore.saveConfig()"
                min="1"
                placeholder="10"
              />
            </div>
            
            <div class="form-group" id="field-logging-max_files">
              <label for="logging-max_files">Nombre max de fichiers</label>
              <input 
                type="number" 
                id="logging-max_files"
                x-model.number="$store.appStore.technicalConfig.logging.rotate.max_files"
                @change.debounce.500ms="$store.appStore.saveConfig()"
                min="1"
                max="100"
                placeholder="5"
              />
            </div>
          </div>
        </div>

        <!-- SOUS-SECTIONS DES MODULES AVEC PARAMÈTRES TECHNIQUES -->
        <template x-for="module in $store.sidebarStore.modules" :key="module.id">
          <template x-if="module.id !== 'core'">
            <div :id="'config-section-' + module.id" class="config-section" x-transition 
                 x-show="$store.appStore.moduleUiMetadata[module.id]"
                 x-init="console.log('[TRACE TEMPLATE] Module:', module.id, '| hasMetadata:', !!$store.appStore.moduleUiMetadata[module.id], '| sidebarModules:', $store.sidebarStore.modules.map(m => m.id))">
              <h3 x-text="module.icon + ' ' + $store.appStore.moduleUiMetadata[module.id].title"></h3>
              <p class="section-description" x-text="$store.appStore.moduleUiMetadata[module.id].description"></p>
              <div x-html="$store.appStore.generateModuleConfigForm(module.id)"></div>
            </div>
          </template>
        </template>

        <div class="section-actions">
          <button @click="$store.appStore.saveConfig()" class="btn btn-primary" :disabled="$store.appStore.saveInProgress">
            <span x-show="!$store.appStore.saveInProgress">Sauvegarder</span>
            <span x-show="$store.appStore.saveInProgress">Sauvegarde en cours...</span>
          </button>
        </div>
      </section>

      <!-- Sections dynamiques pour les applications -->
      <template x-for="module in $store.sidebarStore.modules" :key="module.id">
        <section :id="module.id" class="content-section" x-show="$store.mainContentStore.activeModule === module.id" x-transition>
          <!-- Charger dynamiquement le contenu du module -->
          <div 
            x-ref="moduleContainer"
            x-init="$store.mainContentStore.loadModuleContent(module.id, $refs.moduleContainer)"
            x-show="$store.mainContentStore.moduleContents[module.id]"
          ></div>
          <div x-show="!$store.mainContentStore.moduleContents[module.id]" class="loading-hint">
            Chargement du module...
          </div>
        </section>
      </template>

      <!-- Section par défaut si aucun module sélectionné -->
      <section class="content-section welcome-section" x-show="!$store.mainContentStore.activeModule">
        <div class="welcome-card">
          <h2>Bienvenue</h2>
          <p>Sélectionnez une application dans le menu latéral pour commencer.</p>
          <p x-show="$store.sidebarStore.modules.length === 1">
            Vous avez actuellement uniquement les <strong>Paramètres Techniques</strong> configurés.
          </p>
        </div>
      </section>
    </main>
  </div>

  <!-- ====================================================================== -->
  <!-- LOGS MODAL (optionnel) -->
  <!-- ====================================================================== -->
  <div x-data="$store.logsModalStore" class="modal" x-show="$store.logsModalStore.show" x-transition @keydown.escape="$store.logsModalStore.show = false">
    <div class="modal-content" @click.away="show = false">
      <div class="modal-header">
        <h3>Logs en temps réel</h3>
        <button @click="show = false" class="modal-close">&times;</button>
      </div>
      <div class="modal-body logs-container">
        <div class="logs">
          <template x-for="log in logs" :key="log.ts">
            <div class="log-entry" :class="'log-' + log.level">
              <span class="log-timestamp" x-text="log.ts"></span>
              <span class="log-level" x-text="log.level.toUpperCase()"></span>
              <span class="log-module" x-text="'[' + log.module + ']' "></span>
              <span class="log-message" x-text="log.message"></span>
            </div>
          </template>
        </div>
      </div>
    </div>
  </div>

  <!-- ====================================================================== -->

  <!-- Styles inline pour éviter le FOUC -->
  <style>
    :root {
      --color-bg: #1a1a2e;
      --color-surface: #16213e;
      --color-primary: #0f3460;
      --color-accent: #e94560;
      --color-text: #eaeaea;
      --color-text-muted: #8892a4;
      --color-success: #4caf50;
      --color-warning: #ff9800;
      --color-error: #f44336;
      --radius: 8px;
      --font: 'Segoe UI', system-ui, sans-serif;
    }
    
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: var(--font);
      background: var(--color-bg);
      color: var(--color-text);
      min-height: 100vh;
    }
    
    .app-container {
      display: flex;
      min-height: 100vh;
    }
    
    .sidebar {
      width: 280px;
      background: var(--color-surface);
      border-right: 1px solid rgba(255, 255, 255, 0.1);
      display: flex;
      flex-direction: column;
      position: fixed;
      height: 100vh;
      overflow-y: auto;
    }
    
    .main-content {
      flex: 1;
      margin-left: 280px;
      padding: 2rem;
      overflow-y: auto;
    }
    
    .content-section {
      animation: fadeIn 0.3s ease-out;
    }
    
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
    
    @keyframes slideDown {
      from { opacity: 0; transform: translateY(-100%); }
      to { opacity: 1; transform: translateY(0); }
    }
    
    @keyframes pulse {
      0%, 100% { box-shadow: 0 0 0 0 rgba(244, 67, 54, 0.4); }
      50% { box-shadow: 0 0 0 10px rgba(244, 67, 54, 0); }
    }
    
    .field-highlight {
      animation: pulse 1s ease-in-out;
    }
    
    .loading-hint {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40px;
      color: var(--text-muted);
    }
    
    .loading-hint::before {
      content: '⏳';
      margin-right: 8px;
      animation: spin 1s linear infinite;
    }
    
    .error-hint {
      padding: 20px;
      background: rgba(239, 68, 68, 0.1);
      color: #ef4444;
      border-radius: 4px;
      text-align: center;
    }
    
    @keyframes spin {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }
  </style>
  
  <!-- Update last modified date comment -->
  <script>
    // Update last modified date comment
    function updateLastModifiedDate() {
      const now = new Date();
      const dateStr = now.toISOString().slice(0, 10);
      const timeStr = now.toTimeString().slice(0, 5);
      const dateTimeStr = `${dateStr} ${timeStr}`;
      
      // Update the modification comment in the source
      const head = document.head;
      const comments = head.childNodes;
      for (let i = 0; i < comments.length; i++) {
        if (comments[i].nodeType === Node.COMMENT_NODE && comments[i].textContent.includes('Derniere modification:')) {
          comments[i].textContent = ` Derniere modification: ${dateTimeStr} `;
          break;
        }
      }
    }
    
    // Listen for config save to update the date
    document.addEventListener('alpine:init', () => {
      const store = Alpine.store('appStore');
      if (store) {
        const originalSaveConfig = store.saveConfig;
        store.saveConfig = function() {
          originalSaveConfig.apply(this, arguments);
          updateLastModifiedDate();
        };
      }
    });
  </script>
  
</body>
</html>
