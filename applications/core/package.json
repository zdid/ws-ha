{
  "name": "ha-mqtt-socle",
  "version": "1.0.0",
  "description": "Socle technique commun pour les applications HA/MQTT",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:ui": "tsc -p src/presentation/ui/tsconfig.ui.json",
    "build:watch": "tsc --watch",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:local": "CONFIG_PATH=../../data/config.yaml tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "echo \"Linting not configured yet\"",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "home-assistant",
    "mqtt",
    "websocket",
    "typescript",
    "docker"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@serialport/parser-delimiter": "^13.0.0",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "home-assistant-js-websocket": "^9.6.0",
    "js-yaml": "^4.1.0",
    "mqtt": "^5.0.0",
    "rfxcom": "^2.6.2",
    "serialport": "^13.0.0",
    "socket.io": "^4.6.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.14.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/js-yaml": "^4.0.5",
    "@types/node": "^20.10.5",
    "@types/serialport": "^8.0.5",
    "@types/socket.io-client": "^1.4.36",
    "@types/ws": "^8.5.5",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  }
}
