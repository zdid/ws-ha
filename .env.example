# =============================================================================
# Configuration sensible pour les applications HA/MQTT
# NE PAS COMMITER ce fichier avec des valeurs réelles !
# Copier ce fichier en .env et le modifier avec vos valeurs.
# =============================================================================

# Token d'accès Home Assistant (Long-Lived Access Token)
# Générer via : Profil → Access Tokens → Créer un token
HA_WS_TOKEN="votre_token_ha_ici"

# Configuration MQTT (uniquement pour les applications d'intégration)
# MQTT_USERNAME=""
# MQTT_PASSWORD=""

# Configuration optionnelle du serveur
# WEB_PORT=8080
# WEB_HOST=0.0.0.0

# Niveau de log (debug, info, warn, error)
# LOG_LEVEL=info
